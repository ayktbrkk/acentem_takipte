{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bench migrate",
      "type": "shell",
      "command": "bench --site ${input:benchSite} migrate",
      "options": {
        "cwd": "${workspaceFolder}/.."
      },
      "problemMatcher": []
    },
    {
      "label": "bench restart",
      "type": "shell",
      "command": "bench restart",
      "options": {
        "cwd": "${workspaceFolder}/.."
      },
      "problemMatcher": []
    },
    {
      "label": "bench run-tests",
      "type": "shell",
      "command": "bench --site ${input:benchSite} run-tests --app acentem_takipte",
      "options": {
        "cwd": "${workspaceFolder}/.."
      },
      "problemMatcher": []
    },
    {
      "label": "frontend build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend test:unit",
      "type": "shell",
      "command": "npm run test:unit",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "benchSite",
      "type": "promptString",
      "description": "Bench site name",
      "default": "dev.localhost"
    }
  ]
}
