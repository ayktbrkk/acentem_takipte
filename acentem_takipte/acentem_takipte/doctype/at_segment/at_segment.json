{
 "actions": [],
 "autoname": "format:AT-SEG-.YYYY.-.#####",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": [
  "segment_name",
  "segment_type",
  "channel_focus",
  "office_branch",
  "origin_office_branch",
  "current_office_branch",
  "status",
  "criteria_json",
  "estimated_customer_count",
  "notes"
 ],
 "fields": [
  {
   "fieldname": "segment_name",
   "fieldtype": "Data",
   "label": "Segment Name",
   "reqd": 1
  },
  {
   "default": "Static",
   "fieldname": "segment_type",
   "fieldtype": "Select",
   "label": "Segment Type",
   "options": "Static\nDynamic\nOperational",
   "reqd": 1
  },
  {
   "default": "WHATSAPP",
   "fieldname": "channel_focus",
   "fieldtype": "Select",
   "label": "Channel Focus",
   "options": "WHATSAPP\nSMS\nEmail\nPhone Call",
   "reqd": 1
  },
  {
   "fieldname": "office_branch",
   "fieldtype": "Link",
   "label": "Office Branch",
   "options": "AT Office Branch"
  },
  {
   "fieldname": "origin_office_branch",
   "fieldtype": "Link",
   "label": "Origin Office Branch",
   "options": "AT Office Branch",
   "description": "Branch at creation time (historical, for permission queries per kanon branch model)"
  },
  {
   "fieldname": "current_office_branch",
   "fieldtype": "Link",
   "label": "Current Office Branch",
   "options": "AT Office Branch",
   "description": "Current branch (for operational tasks and transfer flows per kanon branch model)"
  },
  {
   "default": "Draft",
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nActive\nArchived",
   "reqd": 1
  },
  {
   "fieldname": "criteria_json",
   "fieldtype": "Code",
   "label": "Criteria JSON",
   "options": "JSON"
  },
  {
   "default": "0",
   "fieldname": "estimated_customer_count",
   "fieldtype": "Int",
   "label": "Estimated Customer Count",
   "read_only": 1
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "User Note",
   "description": "Free-form text added by the user."
  }
 ],
 "index_web_pages_for_search": 1,
 "links": [],
