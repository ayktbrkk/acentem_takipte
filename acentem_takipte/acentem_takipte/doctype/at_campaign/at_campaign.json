{
 "actions": [],
 "autoname": "format:AT-CAMP-.YYYY.-.#####",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": [
  "campaign_name",
  "segment",
  "template",
  "channel",
  "office_branch",
  "origin_office_branch",
  "current_office_branch",
  "status",
  "scheduled_for",
  "sent_count",
  "matched_customer_count",
  "skipped_count",
  "last_run_on",
  "last_run_summary",
  "notes"
 ],
 "fields": [
  {
   "fieldname": "campaign_name",
   "fieldtype": "Data",
   "label": "Campaign Name",
   "reqd": 1
  },
  {
   "fieldname": "segment",
   "fieldtype": "Link",
   "label": "Segment",
   "options": "AT Segment",
   "reqd": 1
  },
  {
   "fieldname": "template",
   "fieldtype": "Link",
   "label": "Template",
   "options": "AT Notification Template"
  },
  {
   "default": "WHATSAPP",
   "fieldname": "channel",
   "fieldtype": "Select",
   "label": "Channel",
   "options": "WHATSAPP\nSMS\nEmail\nPhone Call",
   "reqd": 1
  },
  {
   "fieldname": "office_branch",
   "fieldtype": "Link",
   "label": "Office Branch",
   "options": "AT Office Branch"
  },
  {
   "fieldname": "origin_office_branch",
   "fieldtype": "Link",
   "label": "Origin Office Branch",
   "options": "AT Office Branch",
   "description": "Branch at creation time (historical, for permission queries per kanon branch model)"
  },
  {
   "fieldname": "current_office_branch",
   "fieldtype": "Link",
   "label": "Current Office Branch",
   "options": "AT Office Branch",
   "description": "Current branch (for operational tasks and transfer flows per kanon branch model)"
  },
  {
   "default": "Draft",
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nPlanned\nRunning\nCompleted\nCancelled",
   "reqd": 1
  },
  {
   "fieldname": "scheduled_for",
   "fieldtype": "Datetime",
   "label": "Scheduled For"
  },
  {
   "default": "0",
   "fieldname": "sent_count",
   "fieldtype": "Int",
   "label": "Sent Count",
   "read_only": 1
  },
  {
   "default": "0",
   "fieldname": "matched_customer_count",
   "fieldtype": "Int",
   "label": "Matched Customer Count",
   "read_only": 1
  },
  {
   "default": "0",
   "fieldname": "skipped_count",
   "fieldtype": "Int",
   "label": "Skipped Count",
   "read_only": 1
  },
  {
   "fieldname": "last_run_on",
   "fieldtype": "Datetime",
   "label": "Last Run On",
   "read_only": 1
  },
  {
   "fieldname": "last_run_summary",
   "fieldtype": "Small Text",
   "label": "Last Run Summary",
   "description": "Summary produced when the campaign is run.",
   "read_only": 1
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "User Note",
   "description": "Free-form text added by the user."
  }
 ],
 "index_web_pages_for_search": 1,
 "links": [],
 "module": "Acentem Takipte",
 "name": "AT Campaign",
 "permissions": [
  {
   "create": 1,
   "delete": 1,
   "email": 1,
   "export": 1,
   "print": 1,
   "read": 1,
   "report": 1,
   "role": "System Manager",
   "share": 1,
   "write": 1
  }
 ],
 "sort_field": "modified",
 "sort_order": "DESC",
 "states": [],
 "track_changes": 1
}
