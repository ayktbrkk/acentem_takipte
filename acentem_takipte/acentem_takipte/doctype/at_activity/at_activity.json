{
  "doctype": "DocType",
  "name": "AT Activity",
  "module": "Acentem Takipte",
  "custom": 0,
  "istable": 0,
  "track_changes": 1,
  "engine": "InnoDB",
  "autoname": "hash",
  "naming_rule": "Random",
  "fields": [
    {
      "fieldname": "activity_title",
      "fieldtype": "Data",
      "label": "Activity Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "activity_type",
      "fieldtype": "Select",
      "label": "Activity Type",
      "options": "Call\nVisit\nNote\nClaim Update\nRenewal Update\nCollection\nCampaign\nReview\nOther",
      "in_list_view": 1
    },
    {
      "fieldname": "source_doctype",
      "fieldtype": "Data",
      "label": "Source DocType"
    },
    {
      "fieldname": "source_name",
      "fieldtype": "Data",
      "label": "Source Record"
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Customer",
      "options": "AT Customer",
      "in_list_view": 1
    },
    {
      "fieldname": "policy",
      "fieldtype": "Link",
      "label": "Policy",
      "options": "AT Policy"
    },
    {
      "fieldname": "claim",
      "fieldtype": "Link",
      "label": "Claim",
      "options": "AT Claim"
    },
    {
      "fieldname": "office_branch",
      "fieldtype": "Link",
      "label": "Office Branch",
      "options": "AT Office Branch"
    },
    {
      "fieldname": "origin_office_branch",
      "fieldtype": "Link",
      "label": "Origin Office Branch",
      "options": "AT Office Branch",
      "description": "The office branch at the time of the record - used for historical reporting and accounting consistency."
    },
    {
      "fieldname": "current_office_branch",
      "fieldtype": "Link",
      "label": "Current Office Branch",
      "options": "AT Office Branch",
      "description": "The current office branch - used for operational work queues and transfer/assignment flows."
    },
    {
      "fieldname": "assigned_to",
      "fieldtype": "Link",
      "label": "Assigned User",
      "options": "User"
    },
    {
      "fieldname": "activity_at",
      "fieldtype": "Datetime",
      "label": "Activity Time",
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Logged\nShared\nArchived",
      "default": "Logged",
      "in_list_view": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Agent",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Accountant",
      "read": 1
    }
  ]
}
