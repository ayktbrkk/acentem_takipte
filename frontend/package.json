{
  "name": "acentem-takipte-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=line,json,junit",
    "e2e:smoke": "playwright test tests/e2e/at-smoke.spec.js",
    "e2e:smoke:ci": "playwright test tests/e2e/at-smoke.spec.js --reporter=line,json,junit",
    "e2e:f4": "playwright test --grep \"F4 desk-free core flows\"",
    "e2e:f4:ci": "playwright test --grep \"F4 desk-free core flows\" --reporter=line,json,junit",
    "e2e:g5": "playwright test --grep \"G5 desk-free QA assist\"",
    "e2e:g5:ci": "playwright test --grep \"G5 desk-free QA assist\" --reporter=line,json,junit",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "frappe-ui": "^0.1.10",
    "pinia": "^3.0.4",
    "vue": "^3.4.38",
    "vue-router": "^4.4.3",
    "vue3-select-component": "^0.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.13.14",
    "@iconify-json/lucide": "^1.2.91",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.24.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.0.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.8.2",
    "unplugin-icons": "^22.5.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.8"
  },
  "overrides": {
    "dompurify@<=3.3.2": "3.3.2"
  }
}
